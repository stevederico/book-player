{
  "name": "book-player",
  "private": false,
  "version": "0.76.0",
  "skateboardVersion": "3.9.0",
  "type": "module",
  "workspaces": [
    "backend"
  ],
  "scripts": {
    "start": "npm run front & npm run server",
    "front": "vite --force --mode development",
    "server": "npm run --workspace=backend start",
    "build": "npm run typecheck && vite build --mode production",
    "prod": "npm run typecheck && vite build --mode production",
    "install-all": "npm install && npm install --workspace=backend",
    "postinstall": "git config core.hooksPath .githooks || true",
    "test": "npm run typecheck && npm run --workspace=backend test",
    "test:watch": "npm run --workspace=backend test:watch",
    "typecheck": "tsc -p tsconfig.json && tsc -p backend/tsconfig.json",
    "verify:ui": "node scripts/verify-ui-version.mjs"
  },
  "dependencies": {
    "@stevederico/skateboard-ui": "3.12.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.1",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "vite": "8.0.13"
  }
}
