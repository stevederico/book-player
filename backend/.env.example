# Backend environment template. The server copies this file to backend/.env on
# first boot if .env is missing. Fill in real values in .env (which is gitignored).

# === Auth (required for sign-in / write endpoints) ===
JWT_SECRET=change-me-to-a-long-random-string

# === Stripe (required for /api/checkout, /api/portal, /api/payment webhook) ===
STRIPE_KEY=
STRIPE_ENDPOINT_SECRET=

# === xAI Grok (required for POST /api/guides/:slug/auto-chapters) ===
XAI_API_KEY=

# === Usage limits ===
FREE_USAGE_LIMIT=20

# === Production overrides ===
# CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# FRONTEND_URL=https://yourdomain.com
# MONGODB_URL=
# POSTGRES_URL=
# DATABASE_URL=
